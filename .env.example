# ── LLM LOCAL (Ollama) ──────────────────────────────────────────────────────
# Usar para desarrollo local. Para AMP en cloud, exponer Ollama con ngrok
# o cambiar a un proveedor cloud (ver abajo).
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=ollama/gemma4:e4b

# ── LLM CLOUD (para deploy en CrewAI AMP) ───────────────────────────────────
# Descomentar el que uses y comentar las variables de Ollama arriba.
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ── PARA USAR OLLAMA DESDE AMP (via túnel) ──────────────────────────────────
# 1. Corre: ngrok http 11434
# 2. Copia la URL pública y úsala aquí
# OLLAMA_BASE_URL=https://xxxx.ngrok-free.app/v1
# OLLAMA_MODEL=ollama/gemma4:e4b
